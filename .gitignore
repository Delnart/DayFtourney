# ============================================================
# Root .gitignore — covers all sub-projects
# GENERATED SECRETS ARE NEVER COMMITTED
# ============================================================

# --- Environment secrets (CRITICAL) ---
.env
**/.env
*.env.local
**/*.env.local

# --- Node.js ---
node_modules/
**/node_modules/
dist/
**/dist/
dist-ssr/
*.local

# --- Python ---
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
env/
*.egg

# --- Data files (tournament state — not for VCS) ---
api/data/tournament.json

# --- Editor ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
