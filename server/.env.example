# Server Environment Variables
# Copy this to .env and fill in your values

# Discord Bot Token (from Discord Developer Portal)
BOT_TOKEN=your_discord_bot_token_here

# Discord Application Client ID
CLIENT_ID=your_client_id_here

# Discord Guild (Server) ID where commands should be registered
GUILD_ID=your_guild_id_here

# Discord channel ID where match results will be posted
RESULTS_CHANNEL_ID=your_results_channel_id_here

# API secret key (optional, for securing the API)
API_SECRET=your_secret_key_here

# Server port (Render sets this automatically)
PORT=3001
