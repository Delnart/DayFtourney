# Bot Environment Variables
# Copy to .env (never commit the actual .env file!)

# Your Discord Bot Token from Developer Portal
BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN

# Discord Server (Guild) ID
GUILD_ID=REPLACE_WITH_YOUR_GUILD_ID

# URL of the deployed API
API_URL=http://localhost:3001

# Must match API_SECRET in api/.env
API_SECRET=REPLACE_WITH_SAME_SECRET_AS_API
