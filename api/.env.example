# API Environment Variables
# Copy to .env (never commit the actual .env file!)

# Port (Render sets this automatically)
PORT=3001

# Secret key the Discord bot sends on every write request
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# Comma-separated list of allowed origins for CORS
# Example: https://dayftourn.netlify.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
