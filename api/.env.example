# API Environment Variables
# Copy to .env (never commit the actual .env file!)

# Port (Render sets this automatically)
PORT=3001

# Secret key the Discord bot sends on every write request
API_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# JWT secret for admin panel sessions
JWT_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET

# URL of the deployed frontend
FRONTEND_URL=https://your-frontend.onrender.com

# MongoDB Connection String
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/tourney?retryWrites=true&w=majority

# Webhook URL for posting match results
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123/abc

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173
